{
  "rewrites": [
    {
      "source": "/terms",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(facebookexternalhit|WhatsApp|Twitterbot|LinkedInBot|Slackbot|TelegramBot|Discordbot|Googlebot|bingbot|Applebot|PinterestBot).*"
        }
      ],
      "destination": "/api/og?path=/terms"
    },
    {
      "source": "/privacy",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(facebookexternalhit|WhatsApp|Twitterbot|LinkedInBot|Slackbot|TelegramBot|Discordbot|Googlebot|bingbot|Applebot|PinterestBot).*"
        }
      ],
      "destination": "/api/og?path=/privacy"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(facebookexternalhit|WhatsApp|Twitterbot|LinkedInBot|Slackbot|TelegramBot|Discordbot|Googlebot|bingbot|Applebot|PinterestBot).*"
        }
      ],
      "destination": "/api/og?path=/"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
